# Copy this file to ".env" in this folder and fill in real values.
# Or use repo root: python-projects/.env/.env (same KEY=value format).
# ".env" files are gitignored and will not be pushed to GitHub.

PUSHOVER_TOKEN=
# Must be "Your User Key" on https://pushover.net (30 letters/digits) — not a device name like v12
PUSHOVER_USER=
# Optional: send only to one device (name from Pushover dashboard)
# PUSHOVER_DEVICE=
# Optional — for your own scripts / future use (Pushover uses user key, not SMS)
PHONE_NUMBER=
